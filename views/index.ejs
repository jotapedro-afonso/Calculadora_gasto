<!DOCTYPE html>
<html>

<head>

    <link rel="stylesheet" href="/css/style.css">


<title>Calculadora de Autonomia</title>


</head>


<body>


<div class="container">


<h2> Calculadora de Autonomia</h2>


<form method="POST" action="/">


<label>
Consumo do veículo (km/kWh)
</label>

<input 
type="number"
step="0.1"
name="consumo"
required>



<label>
Energia disponível da bateria (kWh)
</label>

<input
type="number"
step="0.1"
name="bateria"
required>


<button type="submit">
Calcular
</button>


</form>



<% if(resultado){ %>

<div class="resultado">

<h3>
Distância máxima:
<%= resultado %> km
</h3>

</div>


<% } %>



</div>


</body>


</html>