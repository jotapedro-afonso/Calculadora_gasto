<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/style.css">

    <title>Calculadora de Autonomia</title>

</head>


<body>


    <div class="container">


        <div class="topo">

            <div class="icone">
                ⚡
            </div>

            <h2>
                Calculadora de Autonomia
            </h2>

            <p>
                Descubra até onde seu veículo elétrico pode chegar.
            </p>

        </div>



        <form method="POST" action="/">



            <label>
                Consumo do veículo (km/kWh)
            </label>


            <input type="number" step="0.1" name="consumo" placeholder="Ex: 6.5" required>




            <label>
                Energia disponível da bateria (kWh)
            </label>


            <input type="number" step="0.1" name="bateria" placeholder="Ex: 50" required>




            <button type="submit">

                Calcular autonomia

            </button>



        </form>




        <% if(resultado){ %>


            <div class="resultado">


                <span>
                    🚗 Autonomia estimada
                </span>


                <h3>

                    <%= resultado %> km

                </h3>


                <p>
                    Distância máxima aproximada com a carga atual.
                </p>


            </div>


            <% } %>




    </div>



</body>

</html>